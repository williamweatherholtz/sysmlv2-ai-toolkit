#!/bin/sh
# Engine process (CLAUDE.md §5, CR-11): validation green BEFORE commit — because
# post-commit auto-pushes to canonical main, nothing unvalidated may land.
# Runs only the layer(s) matching staged paths; commits touching no guarded files
# are not slowed. Escape hatch: SKIP_VALIDATE=1.
#
# Forward GUARDS are the Rust authority (D0074 M3/M4): `keel guard <name>` — the python
# validate_*.py guards + query.py were retired at M4 (sprint58). The .engine SysML SEMANTIC
# validators (schema/workflows/instances) remain kernel-based (deep semantics the Rust validator
# does not cover) and still run via conda.
[ "$SKIP_VALIDATE" = "1" ] && { echo "pre-commit: SKIP_VALIDATE=1 — validation skipped"; exit 0; }

all_staged=$(git diff --cached --name-only --diff-filter=ACMR || true)
sysml_staged=$(echo "$all_staged" | grep '\.sysml$' || true)
rust_staged=$(echo "$all_staged" | grep -E '(\.rs$|Cargo\.toml$|Cargo\.lock$)' || true)

CONDA="C:/Users/WilliamWeatherholtz/miniforge3/Scripts/conda.exe"
V=".engine/tools/validate"
SYSMLV2="target/release/keel.exe"

sysml_run() {
    echo "pre-commit: $1"
    "$CONDA" run -n sysml --no-capture-output python "$V/$1" || {
        echo "pre-commit: VALIDATION FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
}

# .engine schema/workflow/instance changes: kernel validators (deep SysML semantics).
if [ -n "$sysml_staged" ]; then
    echo "$sysml_staged" | grep -q '^\.engine/schema/'    && sysml_run validate_schema.py
    echo "$sysml_staged" | grep -q '^\.engine/workflows/' && sysml_run validate_workflows.py
    echo "$sysml_staged" | grep -qE '^\.engine/(decisions|processes|skills|docs|views)/.*\.sysml$' && sysml_run validate_instances.py
fi

# .tracking changes: validated by the Rust authority (D0048) — fast, no JVM. Falls back to the
# kernel validator only if the binary isn't built.
if echo "$sysml_staged" | grep -q '^\.tracking/'; then
    if [ -x "$SYSMLV2" ]; then
        echo "pre-commit: keel validate . (rust authority)"
        "$SYSMLV2" validate . || {
            echo "pre-commit: RUST VALIDATE FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
    else
        # NO kernel fallback (issue026/safeTrackingFallback): kernel validate_tracking validates
        # per-file and FALSE-FAILS the #CharteredBy charter edges (.tracking -> .engine Decisions)
        # + baselines -> schema. The Rust authority (D0048) is the sole correct .tracking validator.
        echo "pre-commit: rust binary missing — .tracking validation SKIPPED (build target/release/keel to enforce)"
    fi
fi

# Forward GUARDS — run the FULL enforced set (`keel guard`, ALL honest-state guards) whenever any
# .sysml changes, so the LOCAL gate matches CI's `guard all` (issue048: a curated per-path subset
# omitted viewpoint-renderer / manifest-coverage / critic-independence / process-skill / actors, so
# a viewpoint-renderer violation passed the hook and only failed in CI). The Rust guards are kernel-
# free + fast (<1s), so running all of them every .sysml commit is cheap. Binary-missing => skip.
# (Assurance — critique-COVERAGE + `assured` readiness — is a NON-BLOCKING burndown, D0098, and is
# deliberately NOT in this enforced set; run `keel assured` / `keel critique-coverage` on demand.)
if [ -n "$sysml_staged" ]; then
    if [ -x "$SYSMLV2" ]; then
        echo "pre-commit: keel guard (all enforced honest-state guards)"
        "$SYSMLV2" guard || {
            echo "pre-commit: GUARD FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
        # .engine reference resolution, KERNEL-FREE (D0112 phase 2/issue067): catches unresolved type
        # refs + unknown imports on .engine instances even when conda/kernel is unavailable.
        echo "pre-commit: keel check-engine ."
        "$SYSMLV2" check-engine . || {
            echo "pre-commit: CHECK-ENGINE FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
    else
        echo "pre-commit: rust binary missing — guards skipped (build target/release/keel to enforce)"
    fi
fi

# Rust validation: clippy -D warnings across the workspace (<5s incremental)
if [ -n "$rust_staged" ] && [ -f "Cargo.toml" ]; then
    echo "pre-commit: cargo clippy"
    cargo clippy --workspace --all-targets -- -D warnings || {
        echo "pre-commit: CARGO CLIPPY FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
fi

exit 0
