#!/bin/sh
# Engine process (CLAUDE.md §5, CR-11): validation green BEFORE commit — because
# post-commit auto-pushes to canonical main, nothing unvalidated may land.
# Runs only the layer(s) matching staged paths; commits touching no guarded files
# are not slowed. Escape hatch: SKIP_VALIDATE=1.
[ "$SKIP_VALIDATE" = "1" ] && { echo "pre-commit: SKIP_VALIDATE=1 — validation skipped"; exit 0; }

all_staged=$(git diff --cached --name-only --diff-filter=ACMR || true)
sysml_staged=$(echo "$all_staged" | grep '\.sysml$' || true)
rust_staged=$(echo "$all_staged" | grep -E '(\.rs$|Cargo\.toml$|Cargo\.lock$)' || true)

CONDA="C:/Users/WilliamWeatherholtz/miniforge3/Scripts/conda.exe"
V=".engine/tools/validate"

sysml_run() {
    echo "pre-commit: $1"
    "$CONDA" run -n sysml --no-capture-output python "$V/$1" || {
        echo "pre-commit: VALIDATION FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
}

# .engine schema/workflow/instance changes: kernel validators (deep SysML semantics).
if [ -n "$sysml_staged" ]; then
    echo "$sysml_staged" | grep -q '^\.engine/schema/'    && sysml_run validate_schema.py
    echo "$sysml_staged" | grep -q '^\.engine/workflows/' && sysml_run validate_workflows.py
    echo "$sysml_staged" | grep -qE '^\.engine/(decisions|processes|skills|docs)/.*\.sysml$' && sysml_run validate_instances.py
fi

# .tracking changes: validated by the Rust authority (D0048) — fast, no JVM (ends the
# kernel-leak, issue004). Falls back to the kernel validator if the binary isn't built.
if echo "$sysml_staged" | grep -q '^\.tracking/'; then
    if [ -x "target/release/sysmlv2.exe" ]; then
        echo "pre-commit: sysmlv2 validate . (rust authority)"
        ./target/release/sysmlv2.exe validate . || {
            echo "pre-commit: RUST VALIDATE FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
    else
        echo "pre-commit: rust binary missing — falling back to kernel validate_tracking"
        sysml_run validate_tracking.py
    fi
fi

# Ceremony-gate ordering guard (pure-Python, no kernel; <1s) — issue010 / D0047.
# Fails if a gate passed while an earlier-ordered gate in the same sprint is unpassed.
if echo "$all_staged" | grep -q '^\.tracking/delivery/'; then
    echo "pre-commit: validate_ceremony.py"
    python "$V/validate_ceremony.py" || {
        echo "pre-commit: CEREMONY ORDERING FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
fi

# Rust validation: clippy -D warnings across the workspace (<5s incremental)
if [ -n "$rust_staged" ] && [ -f "Cargo.toml" ]; then
    echo "pre-commit: cargo clippy"
    cargo clippy --workspace --all-targets -- -D warnings || {
        echo "pre-commit: CARGO CLIPPY FAILED — commit aborted (SKIP_VALIDATE=1 to bypass)"; exit 1; }
fi

exit 0
