        part portGuardsCoverageDoDR1 : TestResult { :>> id = "8250f1b4-734e-40ad-b959-67324775e08f"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "1fe773a"; :>> judgedAt = "2026-06-20"; :>> judgedBy = "claudeOpus"; }
        action portGuardsCeremonyCharter;
