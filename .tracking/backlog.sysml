        part portGuardsCeremonyCharterDoDR1 : TestResult { :>> id = "6a0b9c52-b519-4523-a36d-e882b0f26e11"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "3ecba70"; :>> judgedAt = "2026-06-20"; :>> judgedBy = "claudeOpus"; }
        action portGuardKeystone;
