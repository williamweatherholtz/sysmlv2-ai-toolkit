    verification n06ProcessAsDataCorrectnessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea06-5162738e0603"; :>> title = "Critique n06ProcessAsData — correctness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (unsound logic): is 'agents read+execute rather than carry in prompt' actually realized, or does CLAUDE.md (a prompt-loaded doc) carry the process? SURVIVED: CLAUDE.md is the interaction CONTRACT/router; the executable process steps are authored in .engine/processes and deployed via skills the agent invokes on demand — the substance is model data, not baked into a system prompt. Sound. No correctness defect."; }
    part n06ProcessAsDataCorrectnessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea06-5162738e0604"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n06ProcessAsDataCorrectnessCritique to n06ProcessAsData;

