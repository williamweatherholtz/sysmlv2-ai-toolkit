    // ── n01AtomicItems ──────────────────────────────────────────────────────────
    verification n01AtomicItemsCompletenessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea01-5162738e0101"; :>> title = "Critique n01AtomicItems — completeness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find uncovered cases): (1) aggregates — a sprint / action def groups many items; does 'atomic' forbid legitimate composition? SURVIVED: composition is expressed by containment + typed edges, and the action def is ITSELF an item; 'atomic' bans checklist-blobs INSIDE an item, not structured grouping. (2) artifact kinds outside 'work items' (TestResults, dispositions, measurements) — SURVIVED: each is its own typed item with an id, so the rule reaches them. (3) provenance scalars (sha, dates) — not item-connections, out of scope. No completeness gap."; }
    part n01AtomicItemsCompletenessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea01-5162738e0102"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n01AtomicItemsCompletenessCritique to n01AtomicItems;

    verification n01AtomicItemsCorrectnessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea01-5162738e0103"; :>> title = "Critique n01AtomicItems — correctness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find unsound logic): the need asserts items connect to other items ONLY via the typed edge algebra, yet some attributes (relatedTask, owner) name other items by STRING. Is the need wrong? SURVIVED: the need states the TARGET principle, and the engine has been driving string refs to typed edges (relatedTask prose -> #Resolves, D0077); residual scalar refs are tracked implementation debt, not a defect in the principle, which is sound and load-bearing (it is what makes the typed graph queryable). Immutable identity + typed schema are correct and realized. No correctness defect in the need."; }
    part n01AtomicItemsCorrectnessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea01-5162738e0104"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n01AtomicItemsCorrectnessCritique to n01AtomicItems;

    verification n01AtomicItemsTestabilityCritique : Test { :>> id = "63940516-2c7d-4e8f-ea01-5162738e0105"; :>> title = "Critique n01AtomicItems — testability"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::testability; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (is it verifiable?): 'atomic / single' has no standalone executable predicate — no guard rejects a non-atomic blob, so that adjective alone is soft. SURVIVED (not a fail): the testable substance — typed schema + immutable UUID identity + typed-edge connection — IS verified (keel validate enforces ids/types; the need is satisfied+verified through sr01TypedItems, which carries a verify edge). The soft term is operationalized by its decomposed requirement. Observation (not blocking): atomicity is enforced by review convention, not a dedicated guard. Survives via sr01."; }
    part n01AtomicItemsTestabilityCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea01-5162738e0106"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n01AtomicItemsTestabilityCritique to n01AtomicItems;

    // ── n02DecisionsFirstClass ──────────────────────────────────────────────────
    verification n02DecisionsFirstClassCompletenessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea02-5162738e0201"; :>> title = "Critique n02DecisionsFirstClass — completeness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find uncovered decision shapes): the need names won't-do scope cuts; does it cover decisions that moot an ISSUE rather than a need? SURVIVED: D0077 #Resolves-from-Decision and supersede-from-Decision both exist, so a decision can close needs AND issues. (2) decisions that change process (not work) — covered by #ProspectiveChange/#SafetyChange (D0070). (3) is a 'won't-do' representable? SURVIVED: a Decision that supersedes a Need is the exact mechanism. No completeness gap."; }
    part n02DecisionsFirstClassCompletenessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea02-5162738e0202"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n02DecisionsFirstClassCompletenessCritique to n02DecisionsFirstClass;

    verification n02DecisionsFirstClassCorrectnessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea02-5162738e0203"; :>> title = "Critique n02DecisionsFirstClass — correctness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find unsound logic): is it actually true that a no-action decision is 'as important' — does treating it first-class create noise? SURVIVED: the principle is sound and is what prevents knowledge loss to commit messages/comments (a recorded HIGH critique-class historically); the Decision type + supersede/Resolves edges realize it without noise (decisions are queryable, not interleaved prose). No correctness defect."; }
    part n02DecisionsFirstClassCorrectnessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea02-5162738e0204"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n02DecisionsFirstClassCorrectnessCritique to n02DecisionsFirstClass;

    verification n02DecisionsFirstClassTestabilityCritique : Test { :>> id = "63940516-2c7d-4e8f-ea02-5162738e0205"; :>> title = "Critique n02DecisionsFirstClass — testability"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::testability; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (is it verifiable?): 'as important as' is unfalsifiable rhetoric — you cannot test relative importance. SURVIVED: the OPERATIONAL claim is testable and is what sr02DecisionRecord verifies — decisions (incl. scope cuts) are authored ITEMS, not comments/commit messages; this is checkable (Decision items exist; the no-prose-state rule is guarded). The rhetorical clause carries no untestable obligation. Survives via sr02."; }
    part n02DecisionsFirstClassTestabilityCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea02-5162738e0206"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n02DecisionsFirstClassTestabilityCritique to n02DecisionsFirstClass;

    // ── n03VerificationTraced ───────────────────────────────────────────────────
    verification n03VerificationTracedCompletenessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea03-5162738e0301"; :>> title = "Critique n03VerificationTraced — completeness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find uncovered cases): a verification with NO commit (staged/uncommitted) — does the need cover it? SURVIVED: pre-commit results are transient and the suspicion path treats empty/uncommitted sha conservatively (never spuriously invalidates); the durable record always links to a commit. (2) re-verification — explicitly covered (append, not overwrite). (3) currency — covered (computed from ancestry). No completeness gap."; }
    part n03VerificationTracedCompletenessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea03-5162738e0302"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n03VerificationTracedCompletenessCritique to n03VerificationTraced;

    verification n03VerificationTracedCorrectnessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea03-5162738e0303"; :>> title = "Critique n03VerificationTraced — correctness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find unsound logic): is 'currency computed from ancestry, not stored' sound, or does it misfire on rebases/squashes that rewrite SHAs? SURVIVED: suspicion uses git object reachability (cat-file / ancestry); a rewritten history is a new commit graph the recompute reads correctly, and the conservative-on-git-failure stance prevents false invalidation. Append-only immutability is sound and write-API-enforced. No correctness defect."; }
    part n03VerificationTracedCorrectnessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea03-5162738e0304"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n03VerificationTracedCorrectnessCritique to n03VerificationTraced;

    verification n03VerificationTracedTestabilityCritique : Test { :>> id = "63940516-2c7d-4e8f-ea03-5162738e0305"; :>> title = "Critique n03VerificationTraced — testability"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::testability; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (is it verifiable?): try to find an unverifiable clause. SURVIVED — this is the most testable need: append-only is enforced by the write API (append-result/append-gate-result), commit-linkage is the judgedAgainst field, and ancestry-currency is exactly what `keel suspect` computes and the orient invalidEvidence set checks. Fully operationalized + verified via sr03AppendResults. Strongest lens."; }
    part n03VerificationTracedTestabilityCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea03-5162738e0306"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n03VerificationTracedTestabilityCritique to n03VerificationTraced;

    // ── n04ComputedState ────────────────────────────────────────────────────────
    verification n04ComputedStateCompletenessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea04-5162738e0401"; :>> title = "Critique n04ComputedState — completeness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find uncovered cases): materialized #View caches (serveLiveCache, snapshot-indicators, report HTML) STORE derived data — does the need ('never a field typed into a document') leave them uncovered or contradicted? SURVIVED: §2.1 permits materialized views when marked #View + regenerable from authored facts + git; the need bars AUTHORED truth, and a regenerable cache is not authored truth (D0091's compute-don't-store exception is explicit). 'any other derivable answer' makes the scope exhaustive. No completeness gap."; }
    part n04ComputedStateCompletenessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea04-5162738e0402"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n04ComputedStateCompletenessCritique to n04ComputedState;

    verification n04ComputedStateCorrectnessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea04-5162738e0403"; :>> title = "Critique n04ComputedState — correctness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find unsound logic): is 'always computed, never authored' self-consistent given the engine must author SOMETHING? SURVIVED: the need correctly partitions irreducible authored facts (items, edges, results, recorded judgments) from DERIVABLE answers (status/coverage/trace/suspicion) — only the latter are barred as fields; this is the exact, sound line §2.1 draws and that reviews enforce. No circularity, no correctness defect."; }
    part n04ComputedStateCorrectnessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea04-5162738e0404"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n04ComputedStateCorrectnessCritique to n04ComputedState;

    verification n04ComputedStateTestabilityCritique : Test { :>> id = "63940516-2c7d-4e8f-ea04-5162738e0405"; :>> title = "Critique n04ComputedState — testability"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::testability; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (is it verifiable?): 'never an authored field for ANY derivable answer' is a universal negative — is there a single guard proving the absence of every stored-state field? SURVIVED (not a fail): the property is verified the way universal-negatives are — by audit + per-class rejection (the no-prose-state rule, RESUME.md deletion, review gates rejecting status/coverage attrs) and via sr04ComputedViews (verify edge); the headline derivables (status/coverage/trace/suspicion) are demonstrably computed (orient/coverage/suspect). Observation: enforcement is convention+per-case, not one universal guard. Survives via sr04."; }
    part n04ComputedStateTestabilityCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea04-5162738e0406"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n04ComputedStateTestabilityCritique to n04ComputedState;

    // ── n05GitNative ────────────────────────────────────────────────────────────
    verification n05GitNativeCompletenessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea05-5162738e0501"; :>> title = "Critique n05GitNative — completeness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find uncovered cases): the interaction-history view reads ~/.claude transcripts that are NOT in git — does that violate 'all authored facts live in text files in git'? SURVIVED: those transcripts are an external read-only LENS, not authored facts; every authored fact (items/edges/results/decisions) is in-repo text. (2) the keel-serve.log — gitignored, but it is a runtime log, not an authored fact. No authored truth lives outside git. No completeness gap."; }
    part n05GitNativeCompletenessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea05-5162738e0502"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n05GitNativeCompletenessCritique to n05GitNative;

    verification n05GitNativeCorrectnessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea05-5162738e0503"; :>> title = "Critique n05GitNative — correctness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (find unsound logic): the need says suspicion is over git ancestry 'not wall-clock time', yet items carry wall-clock createdAt/judgedAt fields — contradiction? SURVIVED: the need scopes the ancestry-vs-wall-clock rule to CURRENCY/suspicion specifically (D0050 computes drift via commit ancestry, never timestamps), while the timestamps are recorded provenance (the attestation instant), a distinct irreducible fact — not the currency mechanism. The two coexist correctly. No correctness defect."; }
    part n05GitNativeCorrectnessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea05-5162738e0504"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from n05GitNativeCorrectnessCritique to n05GitNative;

    verification n05GitNativeTestabilityCritique : Test { :>> id = "63940516-2c7d-4e8f-ea05-5162738e0505"; :>> title = "Critique n05GitNative — testability"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::testability; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (is it verifiable?): try to find an unverifiable clause. SURVIVED: facts-are-text-in-git is checkable (the .tracking/.engine .sysml tree under version control); ancestry-based currency is exactly what `keel suspect` / orient compute via git cat-file. Verified via sr05GitNative (verify edge). Fully operationalized — testable end to end."; }
    part n05GitNativeTestabilityCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea05-5162738e0506"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
