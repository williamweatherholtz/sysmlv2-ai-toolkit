    part n06ProcessAsDataTestabilityCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea06-5162738e0606"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
