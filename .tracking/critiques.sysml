    // ── D0085 (traceability diagram = computed view) — dogfood ─────────────────
    verification d0085CompletenessCritique : Test { :>> id = "7d000085-0085-4e85-9c85-516273840085"; :>> title = "Critique d0085 — completeness"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (uncovered cases): (1) offline use — the page loads cytoscape from a CDN, so 'self-contained' is partial (needs network to render). SURVIVED as a stated future option (inline the lib); the DATA is fully embedded. (2) very large model — 2485 nodes; does it stay digestible? SURVIVED: Test/TestResult (the ~1800 edgeless leaves) default OFF, so the initial view is the ~650 traceability-bearing nodes; filters + focus handle the rest. (3) edges to unparsed/external names? SURVIVED: dangling edges are dropped (verified 0 dangling). (4) regenerate-don't-commit enforced? SURVIVED: /*.html git-ignored + the process step + skill anti-patterns. No completeness gap; offline is the only open option, documented."; }
    part d0085CompletenessCritiqueR1 : TestResult { :>> id = "7d000085-0085-4e85-9c85-516273840f85"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "e39e035"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0085CompletenessCritique to d0085;

    verification d0085CorrectnessCritique : Test { :>> id = "7d000085-0085-4e85-9c85-516273840086"; :>> title = "Critique d0085 — correctness"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK: is diagram-as-computed-view-never-committed the correct call? SURVIVED: a rendered diagram is a pure derivation of the authored model — committing it would store a thing that drifts (the §2.1/D0018 failure the engine exists to avoid); regenerate-don't-commit is consistent with coverage/assured. ATTACK: 'self-contained HTML' overclaims (CDN). SURVIVED as an honest documented caveat (data embedded; lib via CDN; inline is a future option). ATTACK: is a diagram even a 'view' or a new artifact type? SURVIVED: D0015 explicitly allows a materialized #View if marked + regenerable — this is exactly that. Decision sound; the CDN-vs-self-contained wording is the only nuance."; }
    part d0085CorrectnessCritiqueR1 : TestResult { :>> id = "7d000085-0085-4e85-9c85-516273840f86"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "e39e035"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0085CorrectnessCritique to d0085;

    verification d0085FeasibilityCritique : Test { :>> id = "7d000085-0085-4e85-9c85-516273840087"; :>> title = "Critique d0085 — feasibility"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::feasibility; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK: is it built + does it work at the full scale? SURVIVED: `sysmlv2 diagram` emits ~515KB valid HTML, 2485 nodes / 270 edges, zero dangling, cytoscape + controls present, default-hidden leaves; clippy --workspace -D warnings + cargo test (32 lib) green. ATTACK: browser perf — cose layout on 2485 nodes if all toggled on could be slow. SURVIVED (mitigated): default-off leaves keep the live graph ~650; toggling all on is an explicit user action with known cost. ATTACK: the HTML template's brace/quote hazards (prior D0083 lesson)? SURVIVED: built via a placeholder .replace (not format!), avoiding brace escaping; live emit parses as valid JSON+HTML. Feasible + demonstrated."; }
    part d0085FeasibilityCritiqueR1 : TestResult { :>> id = "7d000085-0085-4e85-9c85-516273840f87"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "e39e035"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0085FeasibilityCritique to d0085;

    verification d0086CompletenessCritique : Test { :>> id = "7d000086-0086-4e86-9c86-516273840085"; :>> title = "Critique d0086 — completeness"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (uncovered cases): (1) what does a FINDING become — Issue? action? SURVIVED with a scoped answer: v1 writes the failing critique + computes suspicion (critique_suspect); auto-creating an Issue would trip guard issues (untriaged) and a remediation action would trip sprint-coverage, so 'new implementation' rides the normal suspect->frontier flow and the actionable flag is tagged in procedureText — documented, not silently dropped. (2) accept-risk verdict not in v1 UI; SURVIVED: risk-acceptance is the existing issue-disposition flow (a Decision #Resolves the finding), no new verdict needed. (3) reviewing a human-authored element — judgedBy=human may equal createdBy=human, failing independence; SURVIVED as a known edge (the critique guard catches it; review targets are AI-authored in practice). (4) graph-of-arbitrary-view vs whole-model — both built. No completeness gap that isn't a documented scope line."; }
    part d0086CompletenessCritiqueR1 : TestResult { :>> id = "7d000086-0086-4e86-9c86-516273840f85"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "fdaa84c"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0086CompletenessCritique to d0086;

    verification d0086CorrectnessCritique : Test { :>> id = "7d000086-0086-4e86-9c86-516273840086"; :>> title = "Critique d0086 — correctness"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK: is review-as-independent-critique the correct model? SURVIVED: a human reviewing an element they did not author IS an independent critic (D0080); recording the judgment as a linked verification (not a mutation, not a parallel JSON store) keeps text-as-truth (S2.1) and makes the finding defensible + traceable, and induces suspicion exactly as the human directed. ATTACK: does the JSON round-trip risk becoming a shadow store? SURVIVED: apply-review writes the linked critiques into .tracking; the JSON is transport, git-ignored, disposable — the process/skill anti-patterns forbid storing it. ATTACK: does the renderer modularity actually generalize or is it diagram-special-cased? SURVIVED: render consumes run_resolved (the same view engine as the TOML views) for table/review and graph_elements for graph — the diagram is one preset. Sound."; }
    part d0086CorrectnessCritiqueR1 : TestResult { :>> id = "7d000086-0086-4e86-9c86-516273840f86"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "fdaa84c"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0086CorrectnessCritique to d0086;

    verification d0086FeasibilityCritique : Test { :>> id = "7d000086-0086-4e86-9c86-516273840087"; :>> title = "Critique d0086 — feasibility"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::feasibility; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK: is it built + does it work? SURVIVED: `sysmlv2 render <view> --mode graph|table|review` emits valid self-contained HTML for graph (whole-model + view-scoped), table, and review; `apply-review` parses an exported batch and appends parseable critiques (validate clean) + induces suspicion (critique_suspect picked up a finding); clippy --workspace -D warnings + cargo test green. ATTACK: does adding contains/resultof + new edge kinds break the assurance views? SURVIVED: coverage held at 110/0 and all guards pass (new kinds are inert; filters key on specific kinds). ATTACK: append_critique collision/append-only? SURVIVED: next-free <element>HRev<n> index, UUIDs auto-generated, inserts before the package brace — same enforcement as append_result. Feasible + demonstrated."; }
    part d0086FeasibilityCritiqueR1 : TestResult { :>> id = "7d000086-0086-4e86-9c86-516273840f87"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "fdaa84c"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0086FeasibilityCritique to d0086;

    verification d0087CompletenessCritique : Test { :>> id = "7d000087-0087-4e87-9c87-516273840085"; :>> title = "Critique d0087 — completeness"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK (uncovered cases): (1) does the metric set cover the MBSE measurement canon? SURVIVED: verification coverage % (the headline SE leading indicator), requirements volatility (the early-warning sign), traceability completeness (DO-178C/ISO-26262), critique/attestation (model-quality = human rigour + automated tools), flow/velocity (program execution) — mapped to INCOSE DE Measurement Framework + SE Leading Indicators. (2) governed vs total in the % — critique coverage is reported over ALL elements (12%), not just governed; SURVIVED as an honest 'how much is critiqued' health number (the governed gate is separate via guard critique). (3) trends — Stage 1 is point-in-time; git-derived trends are Stage 2 (Sprint 87), documented in D0087, not silently dropped. (4) issue aging needs 'today' which the engine lacks (no Date::now) — handled by reporting counts + oldest date, not a fabricated age. No completeness gap that isn't a documented scope line."; }
    part d0087CompletenessCritiqueR1 : TestResult { :>> id = "7d000087-0087-4e87-9c87-516273840f85"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "9e1aa68"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0087CompletenessCritique to d0087;

    verification d0087CorrectnessCritique : Test { :>> id = "7d000087-0087-4e87-9c87-516273840086"; :>> title = "Critique d0087 — correctness"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::correctness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK: is a report-as-computed-view (no stored snapshot) the correct call? SURVIVED: a metric is a derivation of authored facts; committing a snapshot/CSV/dashboard would store a thing that drifts (the S2.1/D0018 failure), so reports regenerate and trends recompute from git — consistent with coverage/assured/render. ATTACK: did the edge-completeness metric have a direction bug? CAUGHT + FIXED before commit: requirements are the TARGET of #Verify (incoming), not source — the first cut reported 0% via has_outgoing; corrected to count incoming verify edges (now 100%), with a regression-relevant smoke. ATTACK: does it reuse the per-element computations rather than re-deriving? SURVIVED: aggregates compute_coverage/compute_critique_coverage/compute_attestation/compute_readiness/orient — reuse over invention. Sound."; }
    part d0087CorrectnessCritiqueR1 : TestResult { :>> id = "7d000087-0087-4e87-9c87-516273840f86"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "9e1aa68"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
    #Verify dependency from d0087CorrectnessCritique to d0087;

    verification d0087FeasibilityCritique : Test { :>> id = "7d000087-0087-4e87-9c87-516273840087"; :>> title = "Critique d0087 — feasibility"; :>> createdAt = "2026-06-21"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::feasibility; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK: is it built + does it produce sensible numbers? SURVIVED: `sysmlv2 report` emits all four scorecards as JSON + --html cards — live: assurance coverage 100% / critique 12% / attestation 100%, traceability needs+reqs verified 100% + verify-edge 100% (after the direction fix), quality-debt charter-critique-debt 97 / volatility 0%, flow throughput 87 sprints / velocity ~2 pts — all plausible against the known model. clippy --workspace -D warnings + cargo test green (incl pct + report-cards regressions). ATTACK: trends feasibility? Deferred to Stage 2 with a concrete plan (git Model-at-commit via the orient cat-file helpers). Feasible + demonstrated for Stage 1."; }
    part d0087FeasibilityCritiqueR1 : TestResult { :>> id = "7d000087-0087-4e87-9c87-516273840f87"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "9e1aa68"; :>> judgedAt = "2026-06-21"; :>> judgedBy = "claudeOpus"; }
