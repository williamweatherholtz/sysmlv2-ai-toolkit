    // ── n06ProcessAsData ─────────────────────────────────────────────────────────
    verification n06ProcessAsDataCompletenessCritique : Test { :>> id = "63940516-2c7d-4e8f-ea06-5162738e0601"; :>> title = "Critique n06ProcessAsData — completeness"; :>> createdAt = "2026-06-23"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::critique; :>> lens = CritiqueLens::completeness; :>> critiquedBy = CriticKind::aiModel; :>> procedureText = "ATTACK: do some processes live only as SKILL.md prose rather than model data? SURVIVED: processes ARE .engine/processes/*.sysml (data); a skill DEPLOYS a process (the process-skill guard enforces every process has a deploying skill, and forbids inert processes). Workflows/phases/gates are model items; the skill is the deployment vehicle, not the process definition. No completeness gap."; }
    part n06ProcessAsDataCompletenessCritiqueR1 : TestResult { :>> id = "63940516-2c7d-4e8f-ea06-5162738e0602"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "5e14b01"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
