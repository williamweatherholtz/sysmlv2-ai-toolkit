        :>> title = "Sprint 85: modularRenderReview (8 pts) — `sysmlv2 render <view> --mode graph|table|review` + `apply-review` round-trip (review = linked critique, attests state + induces suspicion); render process/skill/viewpoint (D0086)";
        :>> createdAt = "2026-06-21";
