    part indicatorTypeCloseOutGateR1 : TestResult { :>> id = "63940516-2c7d-4e8f-b092-51627384bd0d"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "e35674d"; :>> judgedAt = "2026-06-22"; :>> judgedBy = "claudeOpus"; }

    verification indicatorTypeRetroGate : Test { :>> id = "63940516-2c7d-4e8f-b092-51627384bd0e"; :>> title = "Sprint 92 retro gate (autonomous, D0049)"; :>> createdAt = "2026-06-22"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::analyze; :>> procedureText = "Autonomous retro (D0049). WELL: the human's correction (git is a SPECIALIZED indicator, not the general one) redirected to the right, standards-backed model (ISO-15939/PSM/SMM) — and grounding in that 25-year measurement-information-model made the design fall out cleanly: measure-vs-measurement, objective/subjective method, compute-where-reproducible/author-the-irreducible. The friction case landing as a first-class indicator showing 'improving' is a satisfying close on the original 'forced-into-verification' awkwardness (D0088->D0089). CAUGHT (avoidable-issue candidates, all caught pre-commit): (1) 'at' is a reserved SysML keyword (renamed measuredAt); (2) a bare `dependency from X to Y` parses but is NOT ingested as an edge — needs a #Marker (used #Measures/#Informs); (3) adding the `indicators` subcommand without adding it to the guard's VIEW_SUBCOMMANDS made viewpoint-renderer fail and CASCADE into assured. Lesson: when adding a subcommand that a viewpoint renderer names, update VIEW_SUBCOMMANDS in the same change — the guard set is coupled to the command set. Estimate 8 pts held. The general Indicator capability is operational across all three measurement methods."; }
    part indicatorTypeRetroGateR1 : TestResult { :>> id = "63940516-2c7d-4e8f-b092-51627384bd0f"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "e35674d"; :>> judgedAt = "2026-06-22"; :>> judgedBy = "claudeOpus"; }
