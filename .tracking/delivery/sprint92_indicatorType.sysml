    verification indicatorTypeRefineGate : Test { :>> id = "63940516-2c7d-4e8f-b092-51627384bd04"; :>> title = "Sprint 92 refine gate (DoR)"; :>> createdAt = "2026-06-22"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::inspect; :>> procedureText = "DoR: the human asked to first-class the Indicator (from the D0088 measure spectrum — the friction case kept being forced into the requirement/verification frame), then corrected toward GENERALITY (git is a specialized indicator; need stock/regulation/twitter/survey too; some programmatic, some bespoke). Research grounded it in ISO-15939/PSM/SMM. Signed off: 'build the general model' + 'all 3 methods demonstrated'. Frozen-schema unfreeze accepted (D0089). estimatedPoints=8. #CharteredBy d0089. DoD accepted."; }
