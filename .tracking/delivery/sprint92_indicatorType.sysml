    verification indicatorTypeReviewGate : Test { :>> id = "63940516-2c7d-4e8f-b092-51627384bd0a"; :>> title = "Sprint 92 review gate"; :>> createdAt = "2026-06-22"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::inspect; :>> procedureText = "Diff reviewed. The model is the established ISO-15939/SMM one (measure vs measurement; objective/subjective method), mapped to compute-don't-store: computed series recompute from the repo; pulled/manual are irreducible recorded observations with provenance (a market-share/survey value can't be faked or recomputed — like a TestResult but carrying a value not a verdict). Indicator informs by DIRECTION, not a threshold (D0088) — so the friction case is now a first-class indicator showing 'improving', no longer mis-modeled as an un-verifiable Requirement. The direction-aware status is fully automatable (it needs only a (value,at) series) — nothing quantitative is authored on the Indicator. Honest scope: derived (indicator-of-indicators) measures + automated pulled-collection scrapers are documented future layers; the demonstrators seed pulled/manual data. Frozen-schema discipline held (sign-off, re-freeze). No bare-dependency edges (markers required)."; }
    part indicatorTypeReviewGateR1 : TestResult { :>> id = "63940516-2c7d-4e8f-b092-51627384bd0b"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "e35674d"; :>> judgedAt = "2026-06-22"; :>> judgedBy = "claudeOpus"; }

