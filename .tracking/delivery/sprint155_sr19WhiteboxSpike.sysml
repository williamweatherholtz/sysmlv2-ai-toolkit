    part sr19SpikeStandupGateR1 : TestResult { :>> id = "63940516-2c7d-4e8f-c155-51627384c007"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "80c9363"; :>> judgedAt = "2026-06-24"; :>> judgedBy = "claudeOpus"; }
