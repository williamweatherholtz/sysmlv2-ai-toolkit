        part storyReviewQueueGovDoDR1 : TestResult { :>> id = "63940516-2c7d-4e8f-c228-51627384c003"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "3d36c57"; :>> judgedAt = "2026-07-15"; :>> judgedBy = "claudeOpus"; }
    }

