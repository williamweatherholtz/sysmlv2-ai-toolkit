    part introductionDryRunRetroGateR1 : TestResult { :>> id = "63940516-2c7d-4e8f-c142-51627384c00f"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "7bd115f"; :>> judgedAt = "2026-06-23"; :>> judgedBy = "claudeOpus"; }
