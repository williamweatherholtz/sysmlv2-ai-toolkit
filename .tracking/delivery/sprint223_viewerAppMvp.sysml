// ProjectDeliveryS223 — Sprint 223: viewerAppMvp — BUILD the keel-viewer app MVP (shape B / D0114,
// generative / D0117). A buildless static SPA over keel's committed API that GENERATES its UI from the
// declared model (types/attributes/actions) — nothing per-type hardcoded. Committed to the sysmlv2-viewer
// repo (5f55952); verified end-to-end in a browser against a live keel serve. Satisfies srViewerGenerativeUi
// + srViewerGraphExpand. Recorded per D0118. EXECUTE. 5 pts.
package ProjectDeliveryS223 {
    private import EngineElement::*;
    private import EngineWork::*;
    private import EngineVerification::*;
    private import EngineRequirements::*;
    private import EngineRelationships::*;

    #CharteredBy dependency from viewerAppMvpStory to d0117;

    part viewerAppMvpStory : Story {
        :>> id = "63940516-2c7d-4e8f-c223-51627384c001";
        :>> title = "Sprint 223: viewerAppMvp (5 pts) - build the generative viewer SPA over the keel API (shape B)";
        :>> createdAt = "2026-07-15"; :>> createdBy = "wweatherholtz"; :>> kind = WorkKind::code; :>> priority = WorkPriority::p1; :>> owner = "claudeOpus"; :>> estimatedPoints = 5;
    }

    // the MVP realises these viewer requirements (satisfy <requirement> by <satisfier>)
    satisfy srViewerGenerativeUi by viewerAppMvpStory;
    satisfy srViewerGraphExpand by viewerAppMvpStory;

    action def DeliveryRunS223 {
        action storyViewerAppMvp;
        verification storyViewerAppMvpDoD : Test { :>> id = "63940516-2c7d-4e8f-c223-51627384c002"; :>> method = VerificationMethod::demo; :>> procedureText = "Satisfies srViewerGenerativeUi + srViewerGraphExpand (shape B / D0114, generative / D0117; recorded per D0118). BUILT (sysmlv2-viewer repo, commit 5f55952): a BUILDLESS static SPA (app/index.html + app.js + styles.css + vendored cytoscape; no CDN/toolchain) that consumes keel's committed API and GENERATES its UI from the declared model — (1) discovers the API from GET /api/version (read+write endpoint contract); (2) a schema browser from GET /api/schema (every declared type + its attribute fields — 92 types, nothing hardcoded); (3) an explorable cytoscape graph from GET /api/slice (seed + depth/direction; click=detail, dbl-click=expand neighbours; generative per-type colour palette); (4) generative element detail from GET /api/item/:name (attributes ordered by the type's declared schema + typed edges, click-through); (5) a propose-a-Decision form generated from the Decision type's attributes, POSTing to /api/decision (status=proposed via keel's record process; acceptance stays a separate human gate). VERIFY (demo): live browser run (Playwright) against `keel serve .` — connected + API v1.5.0 discovered (18 read / 4 write); 92 types listed with attributes; slices for d0117 and nViewerGenerativeUi rendered as a graph; generative detail shown (Need/Decision attributes from schema); +Decision enabled via write-endpoint discovery. 0 console errors after the empty-overlay fix. POST /api/decision separately verified against a throwaway root (returns status=proposed) — not clicked live to avoid writing a stray Decision into this repo."; }
        part storyViewerAppMvpDoDR1 : TestResult { :>> id = "63940516-2c7d-4e8f-c223-51627384c003"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "33beb77"; :>> judgedAt = "2026-07-15"; :>> judgedBy = "claudeOpus"; :>> notes = "viewer code at sysmlv2-viewer@5f55952; verified against keel@33beb77 serve."; }
    }

    verification vamRefineGate : Test { :>> id = "63940516-2c7d-4e8f-c223-51627384c004"; :>> title = "Sprint 223 refine gate (DoR)"; :>> createdAt = "2026-07-15"; :>> createdBy = "claudeOpus"; :>> method = VerificationMethod::inspect; :>> procedureText = "DoR: user directed 'build the viewer app'. keel-side substrate ready (/api/schema S220, /api/decision + write discovery S221, CORS S222). Scope: the generative SPA MVP (connect, schema browser, graph explorer, generative detail, propose-Decision). estimatedPoints=5. #CharteredBy d0117. DoR met."; }
