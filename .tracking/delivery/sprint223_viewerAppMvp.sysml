    part vamStandupGateR1 : TestResult { :>> id = "63940516-2c7d-4e8f-c223-51627384c007"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "33beb77"; :>> judgedAt = "2026-07-15"; :>> judgedBy = "claudeOpus"; }
